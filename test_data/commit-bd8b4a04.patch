+        required: false
       MACOS_SIGNING_IDENTITY:
         required: false
       MACOS_SIGNING_CERT_BASE64:
@@ -148,6 +150,11 @@ jobs:
       TAG: ${{ needs.prepare.outputs.tag }}
       VERSION: ${{ needs.prepare.outputs.version }}
       ARTIFACT_ARCH: ${{ matrix.artifact_arch }}
