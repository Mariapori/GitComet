+      WINDOWS_SIGNING_TIMESTAMP_RFC3161: http://timestamp.acs.microsoft.com/
     steps:
       - uses: actions/checkout@v6
         with:
@@ -160,11 +167,87 @@ jobs:
       - name: Cache Rust artifacts
         uses: Swatinem/rust-cache@v2
 
+      - name: Validate Windows signing configuration
+        shell: pwsh
+        run: |
+          $ErrorActionPreference = "Stop"
+
+          $required = @(
+            "AZURE_CREDENTIALS",
+            "WINDOWS_SIGNING_ENDPOINT",
+            "WINDOWS_SIGNING_ACCOUNT_NAME"
+          )
+          $missing = @()
+
+          foreach ($name in $required) {
+            $value = [Environment]::GetEnvironmentVariable($name)
+            if ([string]::IsNullOrWhiteSpace($value)) {
+              $missing += $name
+            }
+          }
+
+          if ($missing.Count -gt 0) {
+            throw "Missing required Windows signing secret(s)/variable(s): $($missing -join ', ')"
+          }
+
+          Write-Host "Using Windows signing profile: $env:WINDOWS_SIGNING_PROFILE_NAME"
+
+      - name: Log into Azure for Windows signing
+        uses: azure/login@v3
+        with:
+          creds: ${{ env.AZURE_CREDENTIALS }}
+
+      - name: Locate SignTool
+        shell: pwsh
+        run: |
+          $ErrorActionPreference = "Stop"
+
+          $kitsRoot = Join-Path ${env:ProgramFiles(x86)} "Windows Kits\10\bin"
+          $signTool = Get-ChildItem -Path $kitsRoot -Recurse -Filter signtool.exe -ErrorAction SilentlyContinue |
+            Where-Object { $_.FullName -match '\\x64\\' } |
+            Sort-Object FullName -Descending |
+            Select-Object -First 1 -ExpandProperty FullName
+
+          if ([string]::IsNullOrWhiteSpace($signTool)) {
+            $signTool = Get-ChildItem -Path $kitsRoot -Recurse -Filter signtool.exe -ErrorAction SilentlyContinue |
+              Sort-Object FullName -Descending |
+              Select-Object -First 1 -ExpandProperty FullName
+          }
+
+          if ([string]::IsNullOrWhiteSpace($signTool)) {
+            throw "Unable to locate signtool.exe on the GitHub Actions runner."
+          }
+
+          "SIGNTOOL_PATH=$signTool" >> $env:GITHUB_ENV
+
       - name: Build release binary
         shell: pwsh
         run: |
           cargo build -p gitcomet --release --locked --features ui-gpui,gix --bin gitcomet
 
+      - name: Sign Windows release binary
+        uses: Azure/artifact-signing-action@v1
+        with:
+          endpoint: ${{ env.WINDOWS_SIGNING_ENDPOINT }}
+          trusted-signing-account-name: ${{ env.WINDOWS_SIGNING_ACCOUNT_NAME }}
+          certificate-profile-name: ${{ env.WINDOWS_SIGNING_PROFILE_NAME }}
+          files-folder: ${{ github.workspace }}\target\release
+          files-folder-filter: gitcomet.exe
+          file-digest: SHA256
+          timestamp-rfc3161: ${{ env.WINDOWS_SIGNING_TIMESTAMP_RFC3161 }}
+          timestamp-digest: SHA256
+          append-signature: false
+
+      - name: Verify signed Windows release binary
+        shell: pwsh
+        run: |
+          $ErrorActionPreference = "Stop"
+
+          $artifactPath = Join-Path $env:GITHUB_WORKSPACE "target\release\gitcomet.exe"
+          & "$env:GITHUB_WORKSPACE\scripts\windows\verify-signed-artifact.ps1" `
+            -Path $artifactPath `
+            -SignToolPath $env:SIGNTOOL_PATH
+
       - name: Package portable ZIP
         shell: pwsh
         run: |
@@ -219,6 +302,29 @@ jobs:
           $msiName = "gitcomet-v${env:VERSION}-windows-${env:ARTIFACT_ARCH}.msi"
           cargo wix --package gitcomet --profile release --nocapture --no-build --bin-path "$wixBin" --output "dist\$msiName"
 
+      - name: Sign Windows MSI installer
+        uses: Azure/artifact-signing-action@v1
+        with:
+          endpoint: ${{ env.WINDOWS_SIGNING_ENDPOINT }}
+          trusted-signing-account-name: ${{ env.WINDOWS_SIGNING_ACCOUNT_NAME }}
+          certificate-profile-name: ${{ env.WINDOWS_SIGNING_PROFILE_NAME }}
+          files-folder: ${{ github.workspace }}\dist
+          files-folder-filter: gitcomet-v${{ env.VERSION }}-windows-${{ env.ARTIFACT_ARCH }}.msi
+          file-digest: SHA256
+          timestamp-rfc3161: ${{ env.WINDOWS_SIGNING_TIMESTAMP_RFC3161 }}
+          timestamp-digest: SHA256
+          append-signature: false
+
+      - name: Verify signed Windows MSI installer
+        shell: pwsh
+        run: |
+          $ErrorActionPreference = "Stop"
+
+          $artifactPath = Join-Path $env:GITHUB_WORKSPACE "dist\gitcomet-v$($env:VERSION)-windows-$($env:ARTIFACT_ARCH).msi"
+          & "$env:GITHUB_WORKSPACE\scripts\windows\verify-signed-artifact.ps1" `
+            -Path $artifactPath `
+            -SignToolPath $env:SIGNTOOL_PATH
+
       - name: Upload Windows artifacts
         uses: actions/upload-artifact@v7
         with:
